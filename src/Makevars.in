CXX_STD = CXX14

MQOBJECTS=massifquant/xcms_massifquant.o massifquant/TrMgr.o massifquant/Tracker.o massifquant/SegProc.o massifquant/DataKeeper.o massifquant/OpOverload.o

OBIOBJECTS=obiwarp/mat.o obiwarp/vec.o obiwarp/xcms_dynprog.o obiwarp/xcms_lmat.o xcms_obiwarp.o

XCMSOBJECTS=mzROI.o util.o xcms_binners.o fastMatch.o init.o

SQLITOBJECTS = sqlite/sqlite3.o

PENSEOBJECTS = pense/robust_scale_location.o pense/rho.o pense/rcpp_parse_config.o pense/r_utilities.o pense/r_robust_utils.o pense/r_pense_regression.o pense/r_mesten_regression.o pense/r_interface_utils.o pense/r_interface.o pense/r_enpy.o pense/r_en_regression.o pense/enpy_psc.o pense/enpy_initest.o

OPTMSOBJECTS = utilities.o sqlite_utilities.o optim_ultra.o lowess.o hclust_ultrafast.o dda_utilities.o spectrumConsensus.o SWATH_DIA_Deconv.o RcppExports.o PerformDIAProcess.o PerformDDAProcess.o DetectPeaks.o DecoSpectra.o linear_regression.o spectra_searching.o export_interfece.o mzClust.o

ENTROBJECTS = entropy.o CleanSpectrum.o SpectralEntropy.o

OBJECTS= $(MQOBJECTS) $(OBIOBJECTS) $(XCMSOBJECTS) $(BATCHOBJECTS) $(SQLITOBJECTS) $(PENSEOBJECTS) $(OPTMSOBJECTS) $(ENTROBJECTS)

# All platform-specific flags are filled in by ../configure based on runtime
# detection. Linux/gcc ends up with just -fopenmp. macOS/Apple-clang picks up
# -Xclang -fopenmp + Homebrew libomp + Homebrew gettext. Never edit by hand.
#
# The FLIBS line below is emitted by configure: on a healthy install it's just
# a comment (R's inherited FLIBS wins); when configure detected stale paths in
# R's FLIBS (happens after brew gcc upgrades or /opt/gfortran version mismatch)
# it emits `FLIBS = <working override>` which fully overrides R's version.
@FLIBS_LINE@

PKG_CPPFLAGS = @EXTRA_CPPFLAGS@
PKG_CFLAGS   = @OPENMP_CFLAGS@
PKG_CXXFLAGS = @OPENMP_CXXFLAGS@ -fstrict-aliasing -Wno-undefined-inline
PKG_LIBS     = @OPENMP_LIBS@ @EXTRA_LIBS@ $(LAPACK_LIBS) $(BLAS_LIBS) $(FLIBS)

.PHONY: all

all: $(SHLIB)

